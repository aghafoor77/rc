# Multi-stage Ollama Dockerfile with pre-loaded model
# Stage 1: Download the model
# Stage 2: Create final image with model baked in

# ============================================================================
# Stage 1: Model Downloader
# ============================================================================
FROM ollama/ollama:latest AS model-downloader

# Accept build argument for model name
ARG OLLAMA_MODEL=llama3:8b

# Set environment variables
ENV OLLAMA_HOST=0.0.0.0:11434
ENV OLLAMA_MODELS=/root/.ollama/models

# Start Ollama and pull the model
RUN echo "Building Ollama image with model: ${OLLAMA_MODEL}" && \
    ollama serve & \
    SERVER_PID=$! && \
    echo "Waiting for Ollama server to start..." && \
    sleep 10 && \
    echo "Pulling model ${OLLAMA_MODEL} (this happens once during image build)..." && \
    ollama pull ${OLLAMA_MODEL} && \
    echo "Model ${OLLAMA_MODEL} downloaded successfully!" && \
    kill $SERVER_PID || true

# ============================================================================
# Stage 2: Final Image with Pre-loaded Model
# ============================================================================
FROM ollama/ollama:latest

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Set environment variables
ENV OLLAMA_HOST=0.0.0.0:11434
ENV OLLAMA_MODELS=/root/.ollama/models

# Copy the downloaded model from stage 1
COPY --from=model-downloader /root/.ollama /root/.ollama

# Copy startup scripts
COPY deployment/start-ollama-simple.sh /usr/local/bin/start-ollama.sh

# Make script executable
RUN chmod +x /usr/local/bin/start-ollama.sh

# Expose Ollama port
EXPOSE 11434

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:11434/api/tags || exit 1

# Use the startup script as entrypoint
ENTRYPOINT ["/usr/local/bin/start-ollama.sh"]

